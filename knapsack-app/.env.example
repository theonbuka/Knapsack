# Supabase cloud sync (optional)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: override table name if you use a custom one
VITE_SUPABASE_SYNC_TABLE=knapsack_user_data

# Optional: email activation redirect target (defaults to <site-origin>/landing)
VITE_SUPABASE_AUTH_REDIRECT_TO=https://your-app-domain/landing
